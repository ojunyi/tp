@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor STORAGE_COLOR
skinparam classBackgroundColor STORAGE_COLOR

package Storage as StoragePackage {

    package "UserPrefs Storage" #F4F6F6 {
        Class "<<interface>>\nUserPrefsStorage" as UserPrefsStorage
        Class JsonUserPrefsStorage
    }

    Class "<<interface>>\nStorage" as Storage
    Class StorageManager

    package "CoursePilot Storage" #F4F6F6 {
        Class "<<interface>>\nCoursePilotStorage" as CoursePilotStorage
        Class JsonCoursePilotStorage
        Class JsonSerializableCoursePilot
        Class JsonAdaptedStudent
        Class JsonAdaptedTag
        Class JsonAdaptedTutorial
    }
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Storage

StorageManager .up.|> Storage
StorageManager -up-> "1" UserPrefsStorage
StorageManager -up-> "1" CoursePilotStorage

Storage -left-|> UserPrefsStorage
Storage -right-|> CoursePilotStorage

JsonUserPrefsStorage .up.|> UserPrefsStorage
JsonCoursePilotStorage .up.|> CoursePilotStorage
JsonCoursePilotStorage ..> JsonSerializableCoursePilot

JsonSerializableCoursePilot --> "*" JsonAdaptedStudent
JsonSerializableCoursePilot --> "*" JsonAdaptedTutorial
JsonAdaptedTutorial --> "*" JsonAdaptedStudent
JsonAdaptedStudent --> "*" JsonAdaptedTag

@enduml
