@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyCoursePilot" as ReadOnlyCoursePilot
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class CoursePilot
Class ModelManager
Class UserPrefs

Class UniqueStudentList
Class Student
Class MatricNumber
Class Email
Class Name
Class Phone
Class Tag
Class UniqueTutorialList
Class Tutorial
Class TutorialCode
Class Day
Class TimeSlot
Class Capacity

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

CoursePilot .up.|> ReadOnlyCoursePilot

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyCoursePilot
ModelManager -left-> "1" CoursePilot
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

CoursePilot *--> "1" UniqueStudentList
UniqueStudentList --> "~* all" Student
Student *--> Name
Student *--> Phone
Student *--> Email
Student *--> MatricNumber
Student *--> "*" Tag

Student -[hidden]up--> I
UniqueStudentList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> MatricNumber
MatricNumber -[hidden]right-> Email

CoursePilot *--> "1" UniqueTutorialList
UniqueTutorialList --> "~* all" Tutorial
Tutorial *--> TutorialCode
Tutorial *--> Day
Tutorial *--> TimeSlot
Tutorial *--> Capacity
Tutorial --> "*" Student

Tag -[hidden]right-> TimeSlot
Tag -[hidden]right-> TutorialCode
Tag -[hidden]right-> Day
Tag -[hidden]right-> Capacity

ModelManager --> "~* filtered" Tutorial
ModelManager --> "~* filtered" Student
@enduml
